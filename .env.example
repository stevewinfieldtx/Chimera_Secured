# ==============================================================================
# Chimera Secured — environment variables template
# ==============================================================================
# Copy this file to `.env` and fill in real values. The root .gitignore already
# protects `.env` and `.env.*` from being committed. Never paste real keys here.
#
#   cp .env.example .env
#   nano .env
#
# All secrets below are placeholders.
# ==============================================================================
#
# Architecture note (important):
#   - Tenant-side components (scorer, CPP builder) run inside the customer's
#     M365 tenant. Email bodies live there and ONLY there.
#   - Railway-side components (CPA mirror, composer training, feedback
#     aggregation) never see email content. The sovereignty constraint is
#     architectural, not a config flag.
# ==============================================================================


# ------------------------------------------------------------------------------
# CPA service (tenant-side, also runs on Railway for mirror)
# ------------------------------------------------------------------------------
# See cpa/README.md for the full env list used by the CPA service itself.
# These are the Chimera-Secured-side references to it.
CPA_API_URL=http://localhost:8400
CPA_API_KEY=


# ------------------------------------------------------------------------------
# CPA mirror (Railway-side, where change-triggered CPP snapshots land)
# ------------------------------------------------------------------------------
# Tenant-side CPAs push CPP-E artifacts here when the content hash changes.
# Leave CPA_MIRROR_URL empty to disable mirroring (fully-local deployments).
CPA_MIRROR_URL=
CPA_MIRROR_API_KEY=


# ------------------------------------------------------------------------------
# Tenant identity (tenant-side scorer + CPA)
# ------------------------------------------------------------------------------
# Tenant-scoped ID assigned by onboarding. Every CPP and feedback record is
# scoped by this. Same-person-in-two-tenants means two separate CPPs under
# two different TENANT_IDs; no cross-tenant leakage.
TENANT_ID=
TENANT_NAME=


# ------------------------------------------------------------------------------
# Mailbox ingestion for CPP building (tenant-side)
# ------------------------------------------------------------------------------
# M365 Graph path — preferred. Register an Azure AD app with Mail.Read scope:
#   https://portal.azure.com -> App registrations -> New registration
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_TARGET_USER=

# IMAP fallback (Hotmail / on-prem Exchange / etc.). Only used if M365 Graph
# is not configured.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_APP_PASSWORD=


# ------------------------------------------------------------------------------
# CPP builder behavior (tenant-side)
# ------------------------------------------------------------------------------
CPP_INITIAL_EMAIL_COUNT=2000
CPP_INCREMENTAL_CRON=0 3 * * *


# ------------------------------------------------------------------------------
# Tenant-side Chimera Secured scorer
# ------------------------------------------------------------------------------
SCORER_PORT=8500
# Local cache TTL for CPPs pulled from the local CPA.
CPP_CACHE_TTL_SECONDS=86400
# Run mode:
#   "shadow"  = score + log, no user-visible action (Phase 0 of pilot)
#   "warn"    = add banner on flagged emails, no blocking (Phase 2)
#   "enforce" = quarantine per policy (Phase 3)
SCORER_MODE=shadow
SCORER_MODEL_VERSION=
SHORT_EMAIL_WORDS=15


# ------------------------------------------------------------------------------
# Composer training pipeline (Railway-side, runs against Enron DB)
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.6
DATABASE_URL=
EVAL_SWARM_SIZE=8


# ------------------------------------------------------------------------------
# Feedback aggregation (Railway-side, opt-in per tenant)
# ------------------------------------------------------------------------------
FEEDBACK_PUSH_ENABLED=false
FEEDBACK_AGGREGATION_URL=
FEEDBACK_AGGREGATION_KEY=


# ------------------------------------------------------------------------------
# Forward-looking (not wired in v1, reserved)
# ------------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
