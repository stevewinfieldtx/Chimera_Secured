# ============================================================================
# CPA Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# --- REQUIRED FOR GRAPH API ENROLLMENT (Azure AD) ---
# Create an App Registration in Azure AD with Mail.Read application permission.
# Grant admin consent. These three values come from that registration.
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret

# --- API SECURITY ---
# Set this to any strong random string. All API calls (except /health and
# /dashboard) must include header: X-API-Key: <this value>
# Leave blank to disable auth (local dev only — never in production).
CPA_API_KEY=change-me-to-a-strong-random-string

# --- DATABASE ---
# Default: SQLite (zero setup, fine for pilots up to ~50 users).
# For production: use Postgres.
# DATABASE_URL=postgresql://user:password@localhost:5432/cpa
# DATABASE_URL=sqlite:///./cpa_data/cpa.db   (this is the default)

# --- STORAGE ---
# Where CPA stores classifier artifacts and the background corpus.
# Default: ./cpa_data (relative to working directory)
# CPA_DATA_DIR=/app/cpa_data
# CPA_ARTIFACTS_DIR=/app/cpa_data/artifacts
# CPA_BACKGROUND_CORPUS=/app/cpa_data/background_corpus.pkl

# --- TUNING (optional, defaults are good for pilots) ---
# CPA_MAX_ENROLL_EMAILS=2000        # Max emails to pull during enrollment
# CPA_MIN_EMAILS_FOR_HEAD=30        # Min emails needed to train a classifier
# CPA_LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR
# CPA_WORKERS=1                     # Uvicorn worker count (1 is fine for pilots)

# --- MIRROR (optional, for Railway push) ---
# CPA_MIRROR_URL=https://your-railway-endpoint/mirror
# CPA_MIRROR_API_KEY=your-mirror-api-key
