# Voice Agent Factory — All Credentials
# Copy to .env and fill in your values. Never commit .env to git.

# === ElevenLabs ===
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# === Twilio ===
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# === Bridge Service ===
# The bridge is shared across all agents — these settings control it.
ORCHESTRATOR_URL=http://localhost:8500
BRIDGE_PORT=3100
BRIDGE_SECRET=
DEFAULT_COLLECTION_ID=general
